# ── TatvaAI Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── API Keys ────────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here
WHISPER_MODEL = small
SARVAM_API_KEY = your_sarvam_api_key_here
SARVAM_STT_MODEL = saaras:v2.5

# ── FFmpeg Override (optional) ──────────────────────────────────────────────────
# Set this ONLY if ffmpeg is not on your system PATH.
# Point to the directory containing the ffmpeg / ffmpeg.exe binary.
#
# Windows example:
#   FFMPEG_PATH=C:\ffmpeg\bin
#
# macOS / Linux example:
#   FFMPEG_PATH=/usr/local/bin
#
# Leave blank to let TatvaAI auto-discover ffmpeg on PATH.
FFMPEG_PATH=

# ── Streamlit Cloud ─────────────────────────────────────────────────────────────
# On Streamlit Community Cloud, ffmpeg is installed via packages.txt.
# You do NOT need FFMPEG_PATH there — leave it empty.


